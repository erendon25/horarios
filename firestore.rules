rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================
    // FUNCIONES DE APOYO
    // ========================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == "admin";
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserData().role == "superadmin";
    }

    function getUserStoreId() {
      return getUserData().storeId;
    }

    function isTrainer() {
      return isAuthenticated() && getUserData().role == "trainer";
    }

    // ========================
    // PERFILES DE PERSONAL
    // ========================
    match /staff_profiles/{profileId} {
      // Cualquier usuario autenticado puede leer perfiles no vinculados (uid == null)
      // para poder usar el flujo de "Vincular cuenta". Los perfiles vinculados solo los
      // puede leer el admin de la tienda, el trainer, o el propio colaborador.
      allow read: if isSuperAdmin() || (
        isAuthenticated() && (
          (isAdmin() && resource.data.storeId == getUserStoreId()) ||
          (isTrainer() && resource.data.storeId == getUserStoreId()) ||
          (resource.data.uid == request.auth.uid) ||
          (!('uid' in resource.data)) ||
          (resource.data.uid == null) ||
          (resource.data.uid == "")
        )
      );
      // Solo Admin/SuperAdmin de la misma tienda crean o eliminan.
      allow create: if isSuperAdmin() || (isAdmin() && request.resource.data.storeId == getUserStoreId());
      
      // Update: Admin cambia todo. Trainer solo cambia skills. Usuario su propio perfil o perfil sin vincular.
      allow update: if isSuperAdmin() || 
                    (isAdmin() && resource.data.storeId == getUserStoreId()) || 
                    (isTrainer() && resource.data.storeId == getUserStoreId() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['skills'])) || 
                    (isAuthenticated() && (
                      resource.data.uid == request.auth.uid ||
                      resource.data.uid == null ||
                      resource.data.uid == "" ||
                      !('uid' in resource.data)
                    ));
      
      allow delete: if isSuperAdmin() || (isAdmin() && resource.data.storeId == getUserStoreId());
    }

    // ========================
    // HORARIOS GENERADOS (Schedules)
    // ========================
    match /schedules/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || isAdmin();
    }

    // ========================
    // FERIADOS TRABAJADOS (Balance)
    // ========================
    match /feriados_trabajados/{docId} {
      allow read: if isSuperAdmin() || (
        isAuthenticated() && (
          (isAdmin() && resource.data.storeId == getUserStoreId()) ||
          (isTrainer() && resource.data.storeId == getUserStoreId()) ||
          (resource.data.uid == request.auth.uid)
        )
      );
      allow create, update, delete: if isSuperAdmin() || isAdmin() || (isAuthenticated() && request.resource.data.uid == request.auth.uid);
    }
    
    // Alias por compatibilidad
    match /worked_holidays/{docId} {
      allow read, write: if isSuperAdmin() || (isAdmin() && resource.data.storeId == getUserStoreId()) || (isAuthenticated() && resource.data.uid == request.auth.uid);
    }

    // ========================
    // HORARIOS DE ESTUDIO
    // ========================
    match /study_schedules/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin() || isSuperAdmin() || isTrainer());
      allow write: if isAuthenticated() && (request.auth.uid == uid || isAdmin() || isSuperAdmin());
    }

    // ========================
    // HORAS EXTRAS
    // ========================
    match /extra_hours/{docId} {
      allow read: if isSuperAdmin() || (
        isAuthenticated() && (
          (isAdmin() && resource.data.storeId == getUserStoreId()) ||
          (isTrainer() && resource.data.storeId == getUserStoreId()) ||
          (resource.data.uid == request.auth.uid)
        )
      );
      allow write: if isSuperAdmin() || isAdmin() || (isAuthenticated() && request.resource.data.uid == request.auth.uid);
    }

    // ========================
    // HISTORIAL DE CESES
    // ========================
    match /ceses/{docId} {
      allow read: if isSuperAdmin() || (isAdmin() && resource.data.storeId == getUserStoreId());
      allow create, update: if isSuperAdmin() || (isAdmin() && request.resource.data.storeId == getUserStoreId());
      allow delete: if isSuperAdmin();
    }

    // ========================
    // REQUERIMIENTOS Y TIENDAS
    // ========================
    match /stores/{storeId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /stores/{storeId}/positioning_requirements/{docId} {
      allow read: if isAuthenticated() && (storeId == getUserStoreId());
      allow write: if isSuperAdmin() || (isAdmin() && storeId == getUserStoreId());
    }

    match /stores/{storeId}/config/{docId} {
      allow read: if isAuthenticated() && (storeId == getUserStoreId() || isAdmin() || isTrainer());
      allow write: if isSuperAdmin() || (isAdmin() && storeId == getUserStoreId());
    }

    match /positioning_requirements/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || isAdmin();
    }

    // ========================
    // USUARIOS (Cuentas de acceso)
    // ========================
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || isSuperAdmin() || isTrainer());
      allow update: if isSuperAdmin() || (isAdmin() && resource.data.storeId == getUserStoreId()) || (isAuthenticated() && request.auth.uid == userId);
      // create: el propio usuario puede crear su documento al registrarse (request.auth.uid == userId)
      allow create: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow delete: if isSuperAdmin();
    }

    // ========================
    // REGLA POR DEFECTO
    // ========================
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
